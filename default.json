{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "automerge": false,
  "minimumReleaseAge": "7 days",
  "extends": [
    "config:best-practices",
    ":disableRateLimiting",
    ":timezone(Asia/Tokyo)",
    ":labels(renovate, dependencies)",
    ":enableVulnerabilityAlertsWithLabel(security)",
    ":semanticCommits"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update _VERSION variables",
      "managerFilePatterns": ["/.*y[a]?ml$/", "/.*sh$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+?)(?: depName=(?<depName>.+?))? packageName=(?<packageName>.+?)(?: versioning=(?<versioning>[a-z-]+?))?\\s.+?_(VERSION|VER|version|ver)(=| = |: )(?<currentValue>.+?)\\s",
        "# renovate: datasource=(?<datasource>[a-z-]+?)(?: depName=(?<depName>.+?))? packageName=(?<packageName>.+?)(?: versioning=(?<versioning>[a-z-]+?))?\\s.+?_(VERSION|VER|version|ver)(=| = |: )\"(?<currentValue>.+?)\"\\s"
      ]
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": ["yaizuuuu/shared-workflows"],
      "minimumReleaseAge": null
    }
  ]
}
