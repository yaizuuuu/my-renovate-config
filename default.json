{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "automerge": false,
  "minimumReleaseAge": "7 days",
  "extends": [
    "config:best-practices",
    ":disableRateLimiting",
    ":timezone(Asia/Tokyo)",
    ":labels(renovate, dependencies)",
    ":enableVulnerabilityAlertsWithLabel(security)",
    ":semanticCommits"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update _VERSION variables",
      "managerFilePatterns": ["/.*y[a]?ml$/", "/.*sh$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+?)(?: depName=(?<depName>.+?))? packageName=(?<packageName>.+?)(?: versioning=(?<versioning>[a-z-]+?))?\\s*(.+?_)?(VERSION|VER|version|ver)(=| = |: )\"?(?<currentValue>.+?)\"?\\s"
      ]
    },
    {
      "customType": "regex",
      "description": "Update biome.json",
      "managerFilePatterns": ["/^biome.json$/"],
      "matchStrings": [
        "https://biomejs.dev/schemas/(?<currentValue>.+?)/schema.json"
      ],
      "datasourceTemplate": "npm",
      "packageNameTemplate": "@biomejs/biome"
    }
  ],
  "packageRules": [
    {
      "groupName": "biome packages",
      "matchDatasources": ["npm"],
      "matchPackageNames": ["@biomejs/biome"]
    },
    {
      "matchPackageNames": ["yaizuuuu/shared-workflows"],
      "minimumReleaseAge": null
    }
  ]
}
